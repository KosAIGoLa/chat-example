# ICE address browsers use for LiveKit media (UDP 50000-50100 / TCP 7881).
# localhost page → 127.0.0.1
# phone/LAN page → your host LAN IP, e.g. 192.168.1.102
LIVEKIT_NODE_IP=127.0.0.1

# Redis requirepass — must match redis --requirepass and ws-server REDIS_PASSWORD
# Change this in production.
REDIS_PASSWORD=chatredis_change_me
