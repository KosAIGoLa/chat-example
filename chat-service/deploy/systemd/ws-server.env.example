# Copy to /etc/ws-ex/ws-server.env and chmod 640
#   sudo install -d -m 755 /etc/ws-ex
#   sudo install -m 640 ws-server.env.example /etc/ws-ex/ws-server.env

SERVER_ADDR=:8080
SHUTDOWN_TIMEOUT=15s

NATS_URL=nats://127.0.0.1:4222

DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=chat
DB_PASSWORD=change-me
DB_NAME=chatdb
# Postgres client pool — keep MaxOpen * instances < Postgres max_connections
DB_MAX_OPEN_CONNS=50
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=1h
DB_CONN_MAX_IDLE_TIME=10m

JWT_SECRET=change-me-in-production
MSG_CRYPTO_KEY=change-me-crypto-32bytes-min!!!!!

MEDIA_DIR=/opt/ws-ex/chat-service/data/voice

# Redis list cache (empty REDIS_ADDR disables)
REDIS_ADDR=127.0.0.1:6379
# Must match redis-server --requirepass
REDIS_PASSWORD=change-me-redis
REDIS_DB=0
REDIS_LIST_TTL=10m
# Redis client pool
REDIS_POOL_SIZE=50
REDIS_MIN_IDLE_CONNS=5
REDIS_MAX_IDLE_CONNS=20
REDIS_POOL_TIMEOUT=4s
REDIS_CONN_MAX_IDLE_TIME=5m
REDIS_CONN_MAX_LIFETIME=30m
REDIS_DIAL_TIMEOUT=3s
REDIS_READ_TIMEOUT=2s
REDIS_WRITE_TIMEOUT=2s

# LiveKit (if used on this host)
# LIVEKIT_URL=ws://127.0.0.1:7880
# LIVEKIT_API_KEY=devkey
# LIVEKIT_API_SECRET=secret
